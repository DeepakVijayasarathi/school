{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=schoolkart;Username=postgres;Password=yourpassword",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "SchoolKart",
    "Audience": "SchoolKartAPI",
    "AccessTokenMinutes": "15"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://app.schoolkart.com"
  ],
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*",
        "Period": "1s",
        "Limit": 20
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AWS": {
    "AccessKey": "",
    "SecretKey": "",
    "Region": "ap-south-1",
    "BucketName": "schoolkart-files"
  },
  "Twilio": {
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "BigBlueButton": {
    "Url": "https://your-bbb-server.com/bigbluebutton/api",
    "Secret": "CHANGE_THIS_TO_YOUR_BBB_SHARED_SECRET"
  }
}
