# ==============================================================================
# SchoolKart ERP — Backend Environment Variables
# Copy this file to .env (never commit .env) and fill in real values.
# In ASP.NET Core the double-underscore (__) maps to nested JSON config keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# Required. Must point to a reachable Postgres instance.
# ------------------------------------------------------------------------------
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=schoolkart;Username=postgres;Password=CHANGE_ME

# ------------------------------------------------------------------------------
# Redis Cache (optional)
# If left as localhost/127.0.0.1 the app falls back to in-memory cache.
# Set to a real Redis endpoint (e.g. "redis-host:6379") to enable distributed
# caching in staging/production.
# ------------------------------------------------------------------------------
ConnectionStrings__Redis=localhost:6379

# ------------------------------------------------------------------------------
# JWT Authentication
# Secret must be at least 32 random characters — use a password manager or:
#   openssl rand -base64 48
# Issuer and Audience must match the values expected by API consumers.
# AccessTokenMinutes controls how long access tokens remain valid.
# ------------------------------------------------------------------------------
Jwt__Secret=CHANGE_ME_min_32_chars_random_string
Jwt__Issuer=SchoolKart
Jwt__Audience=SchoolKartAPI
Jwt__AccessTokenMinutes=15

# ------------------------------------------------------------------------------
# CORS — Frontend Origin
# Comma-separated list of allowed origins in production.
# In development (ASPNETCORE_ENVIRONMENT=Development) any origin is allowed.
# ------------------------------------------------------------------------------
App__FrontendOrigin=https://app.schoolkart.com

# ------------------------------------------------------------------------------
# AWS S3 — File Storage
# Used for uploading documents, profile photos, etc.
# BucketName must already exist in the specified Region.
# ------------------------------------------------------------------------------
AWS__AccessKey=CHANGE_ME
AWS__SecretKey=CHANGE_ME
AWS__Region=ap-south-1
AWS__BucketName=schoolkart-files

# ------------------------------------------------------------------------------
# Twilio — SMS Notifications
# AccountSid and AuthToken are found in the Twilio Console.
# FromNumber must be a Twilio-provisioned number (E.164 format, e.g. +1234567890).
# ------------------------------------------------------------------------------
Twilio__AccountSid=CHANGE_ME
Twilio__AuthToken=CHANGE_ME
Twilio__FromNumber=CHANGE_ME

# ------------------------------------------------------------------------------
# RabbitMQ — Message Broker
# Used for async background jobs (e.g. bulk SMS, payroll processing).
# ------------------------------------------------------------------------------
RabbitMQ__Host=localhost
RabbitMQ__Username=guest
RabbitMQ__Password=CHANGE_ME

# ------------------------------------------------------------------------------
# BigBlueButton — Live Online Classes
# Url is the full API base URL of your BBB server.
# Secret is the shared secret shown on your BBB admin page.
# ------------------------------------------------------------------------------
BigBlueButton__Url=https://your-bbb-server.com/bigbluebutton/api
BigBlueButton__Secret=CHANGE_ME

# ------------------------------------------------------------------------------
# Logging (Serilog)
# Default log level for the application. Override per-namespace as needed.
# Levels: Verbose | Debug | Information | Warning | Error | Fatal
# ------------------------------------------------------------------------------
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning

# ------------------------------------------------------------------------------
# IP Rate Limiting
# Controls built-in AspNetCoreRateLimit behaviour.
# The defaults in appsettings.json (10 logins/min, 20 req/s globally) are
# usually fine; override here only if you need different limits per environment.
# ------------------------------------------------------------------------------
# IpRateLimiting__EnableEndpointRateLimiting=true
# IpRateLimiting__StackBlockedRequests=false

# ------------------------------------------------------------------------------
# ASP.NET Core runtime
# Set to "Development" locally to enable Swagger UI and relaxed CORS.
# Use "Production" (or omit) on servers.
# ------------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000
