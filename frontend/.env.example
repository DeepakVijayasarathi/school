# ==============================================================================
# SchoolKart ERP — Frontend Environment Variables (Next.js)
# Copy this file to .env.local (never commit .env.local) and fill in real values.
# Variables prefixed with NEXT_PUBLIC_ are embedded in the browser bundle —
# do NOT put secrets here.
# ==============================================================================

# ------------------------------------------------------------------------------
# API Base URL
# The root URL of the SchoolKart backend API (no trailing slash).
# In development this is typically http://localhost:5000.
# In production set it to your deployed API domain.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
